# ============================================================
# CareerMind-AI - Production .gitignore
# Python + Flask + Google Gemini + VS Code + Render
# ============================================================

# ----------------------------
# Environment Variables
# ----------------------------
.env
.env.*

# ----------------------------
# Python Virtual Environment
# ----------------------------
venv/
.venv/
env/
ENV/

# ----------------------------
# Python Cache
# ----------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------
# Compiled Python Files
# ----------------------------
*.so
*.pyd
*.pyo

# ----------------------------
# Distribution / Packaging
# ----------------------------
build/
dist/
*.egg-info/
.eggs/

# ----------------------------
# Logs
# ----------------------------
*.log
logs/

# ----------------------------
# Testing
# ----------------------------
.pytest_cache/
.coverage
htmlcov/

# ----------------------------
# IDE / Editor
# ----------------------------
.vscode/
.idea/

# ----------------------------
# Operating System Files
# ----------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------
# Uploads (Temporary Resume Files)
# ----------------------------
uploads/*
!uploads/.gitkeep

# ----------------------------
# Generated Reports (Optional)
# ----------------------------
reports/*
!reports/.gitkeep

# ----------------------------
# Local Database (If Ever Created)
# ----------------------------
*.db
*.sqlite3

# ----------------------------
# Jupyter Notebook
# ----------------------------
.ipynb_checkpoints/

# ----------------------------
# Misc
# ----------------------------
*.tmp
*.temp
